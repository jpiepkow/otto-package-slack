{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.default.slack.read_thread_output",
  "title": "Read Slack thread output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workspace_ref"
  ],
  "properties": {
    "workspace_ref": {
      "$ref": "#/$defs/workspace_ref"
    },
    "channel_ref": {
      "$ref": "#/$defs/channel_ref"
    },
    "thread_ref": {
      "$ref": "#/$defs/thread_ref"
    },
    "messages": {
      "$ref": "#/$defs/messages"
    },
    "channels": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/channel_read"
      }
    },
    "dm_conversations": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/dm_conversation"
      }
    },
    "conversations": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object"
      }
    },
    "channel_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96
    },
    "user_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96
    },
    "truncated": {
      "type": "boolean"
    },
    "redactions_applied": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "enum": ["message_content", "credential_ref", "workspace_ref", "channel_ref", "author_ref"]
      }
    }
  },
  "$defs": {
    "workspace_ref": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^workspace\\.[a-z0-9][a-z0-9._-]{1,94}$"
    },
    "channel_ref": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^channel\\.[a-z0-9][a-z0-9._-]{1,94}$"
    },
    "thread_ref": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "pattern": "^thread\\.[a-z0-9][a-z0-9._-]{1,118}$"
    },
    "message_ref": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "pattern": "^message\\.[a-z0-9][a-z0-9._-]{1,118}$"
    },
    "actor_ref": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^actor\\.[a-z0-9][a-z0-9._-]{1,94}$"
    },
    "messages": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "$ref": "#/$defs/message"
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message_ref", "author_ref", "body", "body_chars"],
      "properties": {
        "message_ref": {
          "$ref": "#/$defs/message_ref"
        },
        "author_ref": {
          "$ref": "#/$defs/actor_ref"
        },
        "sent_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "body": {
          "type": "string",
          "maxLength": 2000
        },
        "body_chars": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2000
        },
        "body_digest": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128,
          "pattern": "^[a-z0-9:._-]+$"
        },
        "reactions": {
          "description": "Bounded reaction summary, present only when the message has reactions and the token carries reactions:read. Reacting member ids are never echoed.",
          "type": "array",
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/reaction"
          }
        },
        "reactions_truncated": {
          "description": "True when the message carried more distinct reactions than the summary cap.",
          "type": "boolean"
        }
      }
    },
    "reaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "count"],
      "properties": {
        "name": {
          "description": "Slack emoji name without surrounding colons.",
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "users_truncated": {
          "description": "True when Slack reported reacting member ids, which are deliberately not echoed into read output.",
          "type": "boolean"
        }
      }
    },
    "channel_read": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_id", "channel_ref", "messages"],
      "properties": {
        "channel_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "channel_ref": {
          "$ref": "#/$defs/channel_ref"
        },
        "messages": {
          "$ref": "#/$defs/messages"
        }
      }
    },
    "dm_conversation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_id", "channel_ref", "messages"],
      "properties": {
        "channel_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "channel_ref": {
          "$ref": "#/$defs/channel_ref"
        },
        "user_id": {
          "type": ["string", "null"],
          "maxLength": 96
        },
        "messages": {
          "$ref": "#/$defs/messages"
        }
      }
    }
  }
}
